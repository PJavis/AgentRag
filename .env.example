# =============================================================================
# AgentRag — Environment Configuration
# Sao chép file này thành .env và điền giá trị phù hợp.
# Xem README.md Section 5 để chọn cấu hình theo phần cứng.
# =============================================================================

# =============================================================================
# API KEYS — chỉ điền provider bạn dùng
# =============================================================================
OPENAI_API_KEY=
GEMINI_API_KEY=
HF_TOKEN=

# Ollama: native local (mặc định) hoặc container (docker compose --profile local-llm up -d)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1/
# OLLAMA_BASE_URL=http://ollama:11434/v1/    # ← dùng dòng này khi app chạy trong Docker cùng network
OLLAMA_API_KEY=ollama

# =============================================================================
# DATABASE & CACHE
# =============================================================================

# PostgreSQL — source of truth (port 5433 tránh conflict với local postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Elasticsearch — BM25 + kNN (agentrag_segments, agentrag_entries, agentrag_synthesis)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_NAME=agentrag_segments

# Redis — chat history cache + ARQ job queue
REDIS_URL=redis://127.0.0.1:6379/0

# =============================================================================
# LLM PROVIDERS
# Providers: openai | gemini | hf_inference | ollama
# AGENT_* để trống → fallback về EXTRACTION_*
# =============================================================================

# Embedding — dùng cho search chunks và kNN
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=32

# Extraction — LLM chính: StructMem extraction, schema discovery, SQL compile
EXTRACTION_PROVIDER=ollama
EXTRACTION_MODEL=qwen2.5:14b-instruct
EXTRACTION_BASE_URL=
EXTRACTION_TEMPERATURE=0.0

# Agent runtime — override EXTRACTION nếu cần model mạnh hơn cho answer/synthesize
AGENT_PROVIDER=ollama
AGENT_MODEL=qwen2.5:14b-instruct
AGENT_BASE_URL=
AGENT_TEMPERATURE=0.5

# =============================================================================
# STRUCTMEM — Knowledge extraction pipeline
# Tất cả STRUCTMEM_* dùng chung prefix thay vì GRAPH_* cũ (không còn graph DB)
# =============================================================================

STRUCTMEM_ENABLED=true
STRUCTMEM_INGEST_MODE=async               # sync: blocking | async: background worker

# Chunk size cho extraction (lớn hơn search chunk để ít episode hơn)
STRUCTMEM_CHUNK_MAX_TOKENS=1536
STRUCTMEM_CHUNK_OVERLAP_TOKENS=128

# Số chunk extract song song trong cùng 1 document job
STRUCTMEM_MAX_CONCURRENCY=3
# Số document jobs 1 ARQ worker xử lý song song.
# Giữ =1 nếu dùng Ollama local để tránh GPU thrashing; tăng lên khi dùng cloud API.
STRUCTMEM_WORKER_MAX_JOBS=1
STRUCTMEM_CHUNK_TIMEOUT_SECONDS=300        # timeout per-chunk (giây)
STRUCTMEM_JOB_TIMEOUT_SECONDS=3600        # timeout toàn bộ ARQ job (phải >> CHUNK * MAX_CONCURRENCY)
STRUCTMEM_CHUNK_RETRIES=3

# Cache kết quả extraction tránh re-extract khi re-ingest cùng content
STRUCTMEM_ENABLE_CACHE=true
STRUCTMEM_CACHE_DIR=.cache/agentrag/extract

# ES indices
STRUCTMEM_ENTRIES_INDEX_NAME=agentrag_entries
STRUCTMEM_SYNTHESIS_INDEX_NAME=agentrag_synthesis

# Cross-chunk consolidation
STRUCTMEM_CONSOLIDATION_THRESHOLD=20      # số chunks tích luỹ trước khi trigger
STRUCTMEM_CONSOLIDATION_HISTORY_TOP_K=15  # top-K historical entries làm seed

# =============================================================================
# CHUNKING (search path)
# =============================================================================

SEARCH_CHUNK_MAX_TOKENS=512
SEARCH_CHUNK_OVERLAP_TOKENS=64
SEARCH_CHUNK_BY_PARAGRAPH=true            # tách ưu tiên theo \n\n trước khi đếm token

# Tokenizer đếm token (model name, tải offline qua tiktoken — không cần API)
CHUNK_TOKENIZER_MODEL=text-embedding-3-large

# =============================================================================
# RETRIEVAL & RERANKING
# =============================================================================

RETRIEVAL_TOP_K=10
RETRIEVAL_NUM_CANDIDATES=50
RETRIEVAL_RRF_K=60                        # hệ số RRF (60 là chuẩn học thuật)

# Reranking — tắt mặc định, bật nếu có đủ VRAM (local) hoặc budget (cloud)
RETRIEVAL_RERANK_ENABLED=false
RETRIEVAL_RERANK_TOP_N=20
RETRIEVAL_RERANK_BACKEND=llm_chat         # llm_chat | local_cross_encoder
RETRIEVAL_RERANK_PROVIDER= ollama              # để trống → fallback AGENT_* → EXTRACTION_*
RETRIEVAL_RERANK_MODEL=dengcao/bge-reranker-v2-m3
RETRIEVAL_RERANK_BASE_URL=
RETRIEVAL_RERANK_TEMPERATURE=0.0

# =============================================================================
# AGENT & CHAT
# =============================================================================

AGENT_MAX_STEPS=4
AGENT_TOOL_TOP_K=5
AGENT_MAX_CONTEXT_CHUNKS=8
CHAT_HISTORY_WINDOW=10
CHAT_REDIS_TTL_SECONDS=300

# =============================================================================
# CHAT STRUCTMEM — bộ nhớ hội thoại semantic (thay thế sliding-window history)
# Yêu cầu ARQ worker đang chạy (arq src.agentrag.worker.settings.WorkerSettings)
# =============================================================================

CHAT_STRUCTMEM_ENABLED=false              # true để bật bộ nhớ hội thoại semantic
CHAT_MEMORY_INDEX=agentrag_chat_entries
CHAT_MEMORY_SYNTHESIS_INDEX=agentrag_chat_synthesis
CHAT_MEMORY_CONSOLIDATION_THRESHOLD=10   # số turns tích luỹ trước khi trigger consolidation
CHAT_MEMORY_TOP_K=8                      # số entries retrieve mỗi lượt

# =============================================================================
# STRUCTURED SQL REASONING
# Cần model ≥ 7B với JSON output tốt (qwen2.5 khuyến nghị)
# =============================================================================

STRUCTURED_REASONING_ENABLED=true
STRUCTURED_CLASSIFIER_METHOD=rule+llm     # rule | llm | rule+llm
STRUCTURED_MAX_CHUNKS_FOR_SCHEMA=10
STRUCTURED_MAX_CHUNKS_FOR_EXTRACT=20
STRUCTURED_SQL_MAX_RETRIES=2
STRUCTURED_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# LLM ROUTING — route task khác nhau sang model khác nhau (tối ưu chi phí)
# =============================================================================

LLM_ROUTING_ENABLED=false
LLM_TASK_MODEL_MAP={"classify":"llama3.2:3b","decide":"llama3.2:3b","schema_discovery":"qwen2.5:14b-instruct","sql_compile":"qwen2.5:14b-instruct","synthesize":"qwen2.5:14b-instruct","answer":"qwen2.5:14b-instruct"}
# Task keys: classify | decide | schema_discovery | sql_compile | synthesize | answer
# Ví dụ Tier 2 (8GB VRAM, Ollama):
# LLM_TASK_MODEL_MAP={"classify":"llama3.2:3b","decide":"llama3.2:3b","answer":"qwen2.5:7b-instruct"}
# Ví dụ Tier 3 (24GB VRAM, Ollama):
# LLM_TASK_MODEL_MAP={"classify":"llama3.2:3b","decide":"llama3.2:3b","schema_discovery":"qwen2.5:14b-instruct","sql_compile":"qwen2.5:14b-instruct","answer":"qwen2.5:32b-instruct"}
# Ví dụ Cloud (OpenAI):
# LLM_TASK_MODEL_MAP={"classify":"gpt-4o-mini","decide":"gpt-4o-mini","schema_discovery":"gpt-4o-mini","sql_compile":"gpt-4o-mini","answer":"gpt-4o"}
LLM_COST_TRACKING_ENABLED=false

# =============================================================================
# ARQ WORKER AUTO-SCALER (scaler.py)
# Chỉ có hiệu lực khi chạy: python scaler.py
# =============================================================================

SCALER_MIN_WORKERS=1                     # số worker tối thiểu luôn chạy
SCALER_MAX_WORKERS=4                     # số worker tối đa
SCALER_SCALE_UP_AT=5                     # +1 worker mỗi N jobs trong queue
SCALER_POLL_SECONDS=5                    # tần suất kiểm tra queue (giây)
SCALER_COOLDOWN_SECONDS=30              # thời gian chờ giữa 2 lần rescale

# =============================================================================
# EXCEL INGEST
# =============================================================================

EXCEL_INGEST_MODE=markdown                # markdown: chunk như text | sql: query trực tiếp

# =============================================================================
# OBSERVABILITY
# =============================================================================

OBSERVABILITY_TRACE_ENABLED=true          # ghi timings_ms trong response /chat
