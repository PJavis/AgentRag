POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pam
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

HF_TOKEN=
HF_OPENAI_BASE_URL=https://router.huggingface.co/v1
OPENAI_API_KEY=
GEMINI_API_KEY=

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1/
OLLAMA_API_KEY=ollama

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123456

GRAPH_INGEST_MODE=async
ENABLE_DOCLING_PARSE=false

EMBEDDING_PROVIDER=hf_inference
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=32

EXTRACTION_PROVIDER=ollama
EXTRACTION_MODEL=llama3.1:8b-instruct-q5_K_M
EXTRACTION_BASE_URL=
EXTRACTION_TEMPERATURE=0.0

GRAPH_EMBEDDING_PROVIDER=ollama
GRAPH_EMBEDDING_MODEL=nomic-embed-text
GRAPH_EMBEDDING_BASE_URL=

SEARCH_CHUNK_MAX_TOKENS=512
SEARCH_CHUNK_OVERLAP_TOKENS=64
GRAPH_CHUNK_MAX_TOKENS=1536
GRAPH_CHUNK_OVERLAP_TOKENS=128
CHUNK_TOKENIZER_MODEL=text-embedding-3-large

GRAPH_MAX_CONCURRENCY=3
GRAPH_CHUNK_TIMEOUT_SECONDS=180
GRAPH_CHUNK_RETRIES=2
GRAPH_ENABLE_CACHE=true
GRAPH_CACHE_DIR=.cache/pam/graph
