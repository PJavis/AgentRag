POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
# Để Alembic và code sau đọc được
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Elasticsearch (dev mode, tắt security)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_NAME=pam_segments
ELASTICSEARCH_ENTITY_INDEX_NAME=pam_entities
ELASTICSEARCH_RELATIONSHIP_INDEX_NAME=pam_relationships

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Neo4j
NEO4J_AUTH=neo4j/neo4j123456
NEO4J_PLUGINS=["apoc"]

# FastAPI (sẽ dùng sau)
FASTAPI_PORT=8000

HF_TOKEN=

OPENAI_API_KEY=
GEMINI_API_KEY=

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1/
OLLAMA_API_KEY=ollama

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

GRAPH_INGEST_MODE=async
ENABLE_DOCLING_PARSE=false

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=
EMBEDDING_BATCH_SIZE=32

EXTRACTION_PROVIDER=ollama
EXTRACTION_MODEL=qwen2.5:7b-instruct
EXTRACTION_BASE_URL=
EXTRACTION_TEMPERATURE=0.0

# Optional: agent runtime model (fallback to EXTRACTION_* if empty)
AGENT_PROVIDER=
AGENT_MODEL=
AGENT_BASE_URL=
AGENT_TEMPERATURE=

GRAPH_EMBEDDING_PROVIDER=ollama
GRAPH_EMBEDDING_MODEL=nomic-embed-text
GRAPH_EMBEDDING_BASE_URL=

SEARCH_CHUNK_MAX_TOKENS=512
SEARCH_CHUNK_OVERLAP_TOKENS=64
GRAPH_CHUNK_MAX_TOKENS=1200
GRAPH_CHUNK_OVERLAP_TOKENS=32
CHUNK_TOKENIZER_MODEL=text-embedding-3-large

GRAPH_MAX_CONCURRENCY=1
GRAPH_CHUNK_TIMEOUT_SECONDS=600
GRAPH_CHUNK_RETRIES=0
GRAPH_ENABLE_CACHE=true
GRAPH_CACHE_DIR=.cache/pam/graph

RETRIEVAL_TOP_K=10
RETRIEVAL_NUM_CANDIDATES=50
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_ENABLED=false
RETRIEVAL_RERANK_TOP_N=20
RETRIEVAL_RERANK_BACKEND=llm_chat
RETRIEVAL_RERANK_PROVIDER=
RETRIEVAL_RERANK_MODEL=
RETRIEVAL_RERANK_BASE_URL=
RETRIEVAL_RERANK_TEMPERATURE=0.0

AGENT_MAX_STEPS=4
AGENT_TOOL_TOP_K=5
AGENT_MAX_CONTEXT_CHUNKS=6
CHAT_HISTORY_WINDOW=10
CHAT_REDIS_TTL_SECONDS=300
